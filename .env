# Application
APP_NAME=MikMongo
APP_ENV=development
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=mikmongo
DB_PASSWORD=mikmongo
DB_NAME=mikmongo
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=mikmongo
RABBITMQ_PASSWORD=mikmongo

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=168h

# Mikrotik
MIKROTIK_HOST=192.168.233.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=r00t

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=sandbox

# Internal Key (WebSocket authentication)
INTERNAL_KEY=mikhmon-ws-internal-key

# Auto-migrate + seed on startup (default: false)
AUTO_MIGRATE=true

# Seed: Default superadmin
SEED_ADMIN_EMAIL=admin@mikmongo.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Super Admin

# Seed: Default router (kosongkan address untuk skip)
SEED_ROUTER_NAME=Router Utama
SEED_ROUTER_ADDRESS=192.168.233.1
SEED_ROUTER_API_PORT=8728
SEED_ROUTER_USERNAME=admin
SEED_ROUTER_PASSWORD=r00t
