#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/butterfly-student/Programing/Mikrotik/mikmongo-fully/web/node_modules/.pnpm/knip@6.0.6/node_modules/knip/node_modules:/home/butterfly-student/Programing/Mikrotik/mikmongo-fully/web/node_modules/.pnpm/knip@6.0.6/node_modules:/home/butterfly-student/Programing/Mikrotik/mikmongo-fully/web/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/butterfly-student/Programing/Mikrotik/mikmongo-fully/web/node_modules/.pnpm/knip@6.0.6/node_modules/knip/node_modules:/home/butterfly-student/Programing/Mikrotik/mikmongo-fully/web/node_modules/.pnpm/knip@6.0.6/node_modules:/home/butterfly-student/Programing/Mikrotik/mikmongo-fully/web/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/knip@6.0.6/node_modules/knip/bin/knip.js" "$@"
else
  exec node  "$basedir/../.pnpm/knip@6.0.6/node_modules/knip/bin/knip.js" "$@"
fi
