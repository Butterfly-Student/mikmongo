# ============================================================
# MikMongo — Environment Configuration Example
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.
# ============================================================


# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=MikMongo
APP_ENV=development          # development | production
APP_PORT=8080


# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=mikmongo
DB_PASSWORD=mikmongo
DB_NAME=mikmongo
DB_SSLMODE=disable           # disable | require | verify-full

# Optional: override all DB_* above with a single DSN.
# DATABASE_URL=postgres://mikmongo:mikmongo@localhost:5432/mikmongo?sslmode=disable


# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=              # leave empty if no auth
REDIS_DB=0


# ------------------------------------------------------------
# RabbitMQ
# ------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=mikmongo
RABBITMQ_PASSWORD=mikmongo


# ------------------------------------------------------------
# JWT / Security
# IMPORTANT: change JWT_SECRET to a random 32+ character string in production.
# ------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-32-char-secret
JWT_EXPIRY=1h                # access token lifetime  (e.g. 15m, 1h)
JWT_REFRESH_EXPIRY=168h      # refresh token lifetime (e.g. 168h = 7 days)


# ------------------------------------------------------------
# Mikrotik Router (primary / default router)
# ------------------------------------------------------------
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=


# ------------------------------------------------------------
# Midtrans Payment Gateway
# Get keys from: https://dashboard.midtrans.com
# ------------------------------------------------------------
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=sandbox  # sandbox | production


# ------------------------------------------------------------
# WhatsApp Gateway — Gowa
# ------------------------------------------------------------
GOWA_BASE_URL=http://localhost:3000
GOWA_USERNAME=
GOWA_PASSWORD=
GOWA_DEVICE_ID=              # leave empty to use the server default
GOWA_TIMEOUT=30              # HTTP timeout in seconds


# ------------------------------------------------------------
# Database Migration & Seeding
# AUTO_MIGRATE=true will run migrations + seed on every server start.
# Leave false in production; run migrations manually instead.
# ------------------------------------------------------------
AUTO_MIGRATE=false

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Administrator
SEED_ADMIN_PHONE=08123456789

SEED_ROUTER_NAME=Main Router
SEED_ROUTER_ADDRESS=192.168.88.1
SEED_ROUTER_API_PORT=8728
SEED_ROUTER_USERNAME=admin
SEED_ROUTER_PASSWORD=


# ============================================================
# Test Configuration  (only used when running integration tests)
# go test -tags=integration ./tests/integration/...
# ============================================================

# -- Test Database --
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=mikhmon
TEST_DB_PASSWORD=secret
TEST_DB_NAME=mikmongo_test

# -- Test Redis (isolated DB=15 so it won't touch production data) --
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_PASSWORD=
TEST_REDIS_DB=15

# -- Test Mikrotik (real device; required only for mikrotik_legacy tag) --
TEST_MIKROTIK_HOST=192.168.88.1
TEST_MIKROTIK_PORT=8728
TEST_MIKROTIK_USER=admin
TEST_MIKROTIK_PASS=
TEST_MIKROTIK_TLS=false
